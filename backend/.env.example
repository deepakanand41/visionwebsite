APP_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/visionwebsite
ADMIN_SECRET_KEY=change-this-to-a-strong-secret-key
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Storage: auto uses S3 when APP_ENV=production and bucket is set; otherwise local uploads/
STORAGE_BACKEND=auto
LOCAL_UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=10485760
UPLOAD_MAX_VIDEO_BYTES=41943040

# AWS S3 (set on production server)
AWS_S3_BUCKET=
AWS_S3_REGION=ap-south-1
AWS_S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Zoho Mail SMTP (form submission notifications)
# India accounts often use smtp.zoho.in — custom domain org mail may use smtppro.zoho.com / smtppro.zoho.in
SMTP_ENABLED=false
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_SECURITY=tls
# Full Zoho email address (must match the mailbox you authenticate with)
SMTP_USERNAME=info@viec.in
# Use Zoho App-Specific Password if 2FA is enabled (Mail → Settings → Security → App Passwords)
# Wrap in quotes if the password contains # or $ characters
SMTP_PASSWORD=
SMTP_FROM_EMAIL=info@viec.in
SMTP_FROM_NAME=Vision International
SMTP_NOTIFY_TO=info@viec.in
# Fallback recipient for test emails only — form submissions go to the email entered in the form
# Leave true in production. Set false only for local Mac debugging if SSL certs fail.
SMTP_SSL_VERIFY=true
