DATABASE_URL=postgresql://postgres:password@localhost:5432/visionwebsite
ADMIN_SECRET_KEY=change-this-to-a-strong-secret-key
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Storage: auto = S3 on EC2 when bucket is set, otherwise local uploads/
STORAGE_BACKEND=auto
LOCAL_UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=10485760
UPLOAD_MAX_VIDEO_BYTES=41943040

# AWS S3 (required on EC2 production)
AWS_S3_BUCKET=
AWS_S3_REGION=ap-south-1
AWS_S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
